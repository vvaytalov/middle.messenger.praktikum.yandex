{
    "name": "vvaytalov",
    "version": "1.0.0",
    "description": "vvaytalov chat for yandex",
    "main": "index.ts",
    "scripts": {
        "build": "webpack --config webpack.prod.js",
        "build:docker": "docker build -t chat .",
        "dev": "webpack serve --config webpack.dev.js",
        "start": "npm run build && node ./src/server.js",
        "test": "mocha",
        "test:e2e": "playwright test",
        "typecheck": "tsc --noEmit",
        "stylelint": "stylelint '**/*.css'",
        "lint": "eslint src --ext .js,.ts && npx stylelint \"**/*.css\"",
        "fix": "eslint src --ext .js,.ts --fix && npx stylelint \"**/*.css\" --fix",
        "precommit": "npm-run-all lint fix stylelint"
    },
    "directories": {
        "src": "./src",
        "test": "./test"
    },
    "keywords": [],
    "author": "vvaytalov",
    "license": "ISC",
    "devDependencies": {
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-typescript": "^7.28.5",
        "@babel/register": "^7.28.6",
        "@playwright/test": "^1.59.1",
        "@types/chai": "4.3.0",
        "@types/jsdom": "16.2.14",
        "@types/mocha": "9.1.0",
        "@types/node": "17.0.21",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "chai": "4.3.6",
        "clean-webpack-plugin": "4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "6.7.1",
        "eslint": "^8.57.1",
        "eslint-config-airbnb-base": "15.0.0",
        "eslint-config-airbnb-typescript": "^18.0.0",
        "eslint-plugin-import": "2.25.4",
        "html-webpack-plugin": "5.5.0",
        "husky": "7.0.4",
        "jsdom": "^29.0.2",
        "mini-css-extract-plugin": "2.6.0",
        "mocha": "^11.7.5",
        "npm-run-all": "4.1.5",
        "postcss": "^8.5.10",
        "postcss-calc": "^10.1.1",
        "postcss-nested": "^7.0.2",
        "sass": "^1.99.0",
        "stylelint": "^16.26.1",
        "ts-loader": "9.2.8",
        "tsconfig-paths-webpack-plugin": "3.5.2",
        "typescript": "^5.9.3",
        "webpack": "^5.106.2",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.3"
    },
    "dependencies": {
        "connect-history-api-fallback": "1.6.0",
        "express": "^4.22.1",
        "express-rate-limit": "6.3.0",
        "helmet": "5.0.2"
    }
}
